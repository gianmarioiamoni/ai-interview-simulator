# AI Interview Simulator — Environment Variables
# Copy to .env and populate before running locally.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Required if no local Chroma corpus is present (startup will restore from HF)
CORPUS_HF_REPO=username/interview-corpus

# ── Optional ──────────────────────────────────────────────────────────────────
# Required only for private HF repos
# HF_TOKEN=hf_...

# Model configuration
# CHAT_MODEL=gpt-4o-mini
# CHAT_TEMPERATURE=0.0
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Feature flags
# HUMANIZER_ENABLED=true
# HUMANIZER_FOLLOW_UP_ENABLED=false
# CODING_DOMAIN_PROFILE_ENABLED=true

# Server (local only)
# PORT=7860
# SERVER_HOST=0.0.0.0
